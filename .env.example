# ─────────────────────────────────────────────────────────────────────────────
# PMS — Pension Management System
# .env.example  —  Copy to .env and fill in real values.
#                  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local single-node replica set (required for multi-document transactions):
#   mongod --replSet rs0 --port 27017
#   # in mongosh: rs.initiate()
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB_NAME=pension_management_system

# ── FastAPI ───────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=replace_with_a_long_random_string_for_jwt_signing

# ── OTP / SMS Gateway ─────────────────────────────────────────────────────────
# MSG91 (India) or Twilio — used by Dual-Key Governance for OTP dispatch
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=replace_with_msg91_auth_key
MSG91_SENDER_ID=PMSSAV
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Notification Channels ─────────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── Application ───────────────────────────────────────────────────────────────
RETIREMENT_AGE=60
PENSION_SPLIT_RATIO=0.80
LIQUID_SPLIT_RATIO=0.20
DEFAULT_SURVIVAL_MINIMUM=150.0
INSURANCE_SCORE_THRESHOLD=800
